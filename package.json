{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "type-check": "vue-tsc --noEmit || true",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint . --ext .vue,.js,.ts",
        "format": "prettier --write .",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{vue,js,ts}": [
            "prettier --write --ignore-unknown",
            "eslint --fix"
        ],
        "*.php": [
            "vendor/bin/pint"
        ]
    },
    "devDependencies": {
        "@inertiajs/vue3": "^2.0.0",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.0.0",
        "@types/dompurify": "^3.0.5",
        "@vitejs/plugin-vue": "^6.0.3",
        "@types/node": "^22.10.2",
        "@vue/test-utils": "^2.4.6",
        "autoprefixer": "^10.4.12",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^8.57.0",
        "eslint-plugin-vue": "^9.27.0",
        "husky": "^9.1.7",
        "jsdom": "^25.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "lint-staged": "^15.2.10",
        "postcss": "^8.4.31",
        "prettier": "^3.3.3",
        "tailwindcss": "^3.2.1",
        "typescript": "^5.6.3",
        "vite": "^7.0.7",
        "vitest": "^2.1.5",
        "vue": "^3.4.0",
        "vue-tsc": "^2.1.10"
    },
    "dependencies": {
        "apexcharts": "^5.12.0",
        "dompurify": "^3.4.5",
        "jsbarcode": "^3.12.3",
        "leaflet": "^1.9.4",
        "lodash-es": "^4.17.22",
        "vue-i18n": "^10.0.8",
        "vue-tel-input": "^9.5.1",
        "vue3-apexcharts": "^1.11.1",
        "vuedraggable": "^4.1.0"
    }
}
