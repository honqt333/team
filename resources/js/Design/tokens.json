{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Carag V2 Design Tokens — single source of truth for the visual language. Generated into CSS custom properties by tokens.css. Brand: gold accent (#fbbf24) over slate base, bilingual (light + dark).",
  "color": {
    "brand": {
      "primary": {
        "value": "#fbbf24",
        "$description": "Carag gold — accent color used for primary actions, highlights, and brand surfaces."
      },
      "primaryHover": {
        "value": "#f59e0b",
        "$description": "Hover/active state for primary brand."
      },
      "primaryActive": {
        "value": "#d97706",
        "$description": "Pressed state for primary brand."
      },
      "primarySoft": {
        "value": "#fef3c7",
        "$description": "Soft tint of brand gold for backgrounds and hover surfaces (light)."
      },
      "primarySoftDark": {
        "value": "rgba(251, 191, 36, 0.16)",
        "$description": "Soft tint of brand gold for backgrounds and hover surfaces (dark)."
      }
    },
    "base": {
      "background": {
        "light": "#f8fafc",
        "dark": "#0f172a"
      },
      "surface": {
        "light": "#ffffff",
        "dark": "#1e293b"
      },
      "surfaceMuted": {
        "light": "#f1f5f9",
        "dark": "#334155"
      },
      "surfaceRaised": {
        "light": "#ffffff",
        "dark": "#1e293b"
      },
      "border": {
        "light": "#e2e8f0",
        "dark": "#334155"
      },
      "borderStrong": {
        "light": "#cbd5e1",
        "dark": "#475569"
      }
    },
    "text": {
      "primary": {
        "light": "#0f172a",
        "dark": "#f1f5f9"
      },
      "secondary": {
        "light": "#475569",
        "dark": "#cbd5e1"
      },
      "muted": {
        "light": "#94a3b8",
        "dark": "#64748b"
      },
      "inverse": {
        "light": "#ffffff",
        "dark": "#0f172a"
      },
      "onBrand": {
        "value": "#0f172a",
        "$description": "Text/icon color that sits on the gold brand surface — slate-900 for contrast."
      }
    },
    "feedback": {
      "success": "#16a34a",
      "successSoft": "#dcfce7",
      "warning": "#f59e0b",
      "warningSoft": "#fef3c7",
      "danger": "#dc2626",
      "dangerSoft": "#fee2e2",
      "info": "#0ea5e9",
      "infoSoft": "#e0f2fe"
    },
    "focus": {
      "ring": "#fbbf24",
      "ringSoft": "rgba(251, 191, 36, 0.4)"
    }
  },
  "space": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem"
  },
  "radius": {
    "none": "0",
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "xl": "1rem",
    "2xl": "1.25rem",
    "full": "9999px"
  },
  "fontSize": {
    "xs": "0.75rem",
    "sm": "0.875rem",
    "base": "1rem",
    "lg": "1.125rem",
    "xl": "1.25rem",
    "2xl": "1.5rem",
    "3xl": "1.875rem",
    "4xl": "2.25rem"
  },
  "fontWeight": {
    "regular": "400",
    "medium": "500",
    "semibold": "600",
    "bold": "700"
  },
  "lineHeight": {
    "tight": "1.25",
    "snug": "1.375",
    "normal": "1.5",
    "relaxed": "1.625"
  },
  "fontFamily": {
    "sans": "'IBM Plex Sans Arabic', 'Tajawal', 'Noto Kufi Arabic', 'Inter', system-ui, -apple-system, sans-serif",
    "display": "'Tajawal', 'IBM Plex Sans Arabic', 'Noto Kufi Arabic', system-ui, sans-serif",
    "mono": "'JetBrains Mono', 'Fira Code', ui-monospace, SFMono-Regular, monospace"
  },
  "motion": {
    "duration": {
      "fast": "120ms",
      "base": "180ms",
      "slow": "280ms",
      "slower": "400ms"
    },
    "ease": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "emphasized": "cubic-bezier(0.3, 0, 0, 1)",
      "decelerated": "cubic-bezier(0, 0, 0.2, 1)"
    }
  },
  "shadow": {
    "none": "none",
    "xs": "0 1px 2px 0 rgba(15, 23, 42, 0.05)",
    "sm": "0 1px 3px 0 rgba(15, 23, 42, 0.08), 0 1px 2px 0 rgba(15, 23, 42, 0.04)",
    "md": "0 4px 6px -1px rgba(15, 23, 42, 0.10), 0 2px 4px -2px rgba(15, 23, 42, 0.06)",
    "lg": "0 10px 15px -3px rgba(15, 23, 42, 0.10), 0 4px 6px -4px rgba(15, 23, 42, 0.05)",
    "xl": "0 20px 25px -5px rgba(15, 23, 42, 0.12), 0 8px 10px -6px rgba(15, 23, 42, 0.05)",
    "focus": "0 0 0 4px rgba(251, 191, 36, 0.4)"
  },
  "zIndex": {
    "hide": "-1",
    "base": "0",
    "raised": "10",
    "dropdown": "1000",
    "sticky": "1100",
    "modal": "1300",
    "popover": "1400",
    "toast": "1700"
  },
  "size": {
    "controlSm": "2.25rem",
    "controlMd": "2.75rem",
    "controlLg": "3.25rem",
    "iconSm": "1rem",
    "iconMd": "1.25rem",
    "iconLg": "1.5rem"
  }
}
